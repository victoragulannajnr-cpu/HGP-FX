                tabLogin.className = "w-1/2 text-center py-2 text-xs font-bold rounded-lg transition text-slate-400 hover:text-white";
            } else {
                isSignupActive = false;
                signupField.classList.add('hidden');
                authSubmitBtn.innerText = "Establish Session Router";
                tabLogin.className = "w-1/2 text-center py-2 text-xs font-bold rounded-lg transition bg-amber-500 text-slate-950";
                tabSignup.className = "w-1/2 text-center py-2 text-xs font-bold rounded-lg transition text-slate-400 hover:text-white";
            }
        }

        // Standard Email/Password Gateway Handler
        window.handleAuthGateway = async function(event) {
            event.preventDefault();
            const email = document.getElementById('authEmail').value.trim();
            const password = document.getElementById('authPassword').value;

            if (isSignupActive) {
                try {
                    const userCredential = await createUserWithEmailAndPassword(auth, email, password);
                    await sendEmailVerification(userCredential.user);
                    alert("Registration Complete! A verification link has been sent to your inbox. Please verify before logging in.");
                    await signOut(auth);
                    toggleAuthMode('login');
                } catch (error) {
                    alert("Registration Fault: " + error.message);
                }
            } else {
                try {
                    const userCredential = await signInWithEmailAndPassword(auth, email, password);
                    if (!userCredential.user.emailVerified) {
                        alert("Access Blocked: Your email address has not been verified yet.");
                        await signOut(auth);
                        return;
                    }
                    logSystemActivity("Terminal handshake success for " + userCredential.user.email);
                } catch (error) {
                    alert("Security Access Denied: " + error.message);
                }
            }
        }

        // Live Google Authentication Popup Router
        window.handleGoogleSignIn = async function() {
            try {
                const result = await signInWithPopup(auth, googleProvider);
                logSystemActivity("Google OAuth verification success for " + result.user.email);
                alert("Secure Session Authorized via Google.");
            } catch (error) {
                alert("Google Authentication Cancelled: " + error.message);
            }
        }

        // Active State Watcher: Monitors User Sessions Live
        onAuthStateChanged(auth, async (user) => {
            const authModal = document.getElementById('authModal');
            const appContainer = document.getElementById('appContainer');
            const activeUserDisplay = document.getElementById('activeUserDisplay');

            if (user && user.emailVerified) {
                currentUser = user;
                activeUserDisplay.innerText = user.email;
                
                await fetchUserLedgerProfile(user);
                
                authModal.classList.add('hidden');
                appContainer.classList.remove('filter', 'blur-md', 'pointer-events-none');
                runActiveCalculation();
            } else {
                currentUser = null;
                activeUserDisplay.innerText = "unresolved@hgpfx.io";
                authModal.classList.remove('hidden');
                appContainer.classList.add('filter', 'blur-md', 'pointer-events-none');
            }
        });

        // Disconnect Current Authentication Session Route
        window.triggerLogoutSession = async function() {
            try {
                await signOut(auth);
                document.getElementById('authEmail').value = '';
                document.getElementById('authPassword').value = '';
                if(document.getElementById('authName')) document.getElementById('authName').value = '';
                document.getElementById('ledgerActivityLogs').innerHTML = `<p class="text-slate-500 italic">No historical activities located on standard node connection stack.</p>`;
            } catch (error) {
                console.error("Logout Error:", error);
            }
        }

        // Allocation Dynamic Calculations Modifiers
        window.selectPlanToCalculate = function(planId, planLabel) {
            systemState.activePlanId = planId;
            document.getElementById('calcPlanName').value = planLabel;
            document.getElementById('calcAmount').value = systemState.plans[planId].minDeposit;
            runActiveCalculation();
        }

        window.runActiveCalculation = function() {
            const chosenPlan = systemState.plans[systemState.activePlanId];
            const currentInputValue = parseFloat(document.getElementById('calcAmount').value) || 0;
            const computedMonthlyResult = currentInputValue * chosenPlan.monthlyRate;
            const computedYearlyResult = currentInputValue + (computedMonthlyResult * 12);

            document.getElementById('calcMonthlyYield').innerText = '$' + computedMonthlyResult.toLocaleString(undefined, {minimumFractionDigits: 2});
            document.getElementById('calcYearlyYield').innerText = '$' + computedYearlyResult.toLocaleString(undefined, {minimumFractionDigits: 2});
        }

        window.commitInvestmentToLedger = async function() {
            const targetTier = systemState.plans[systemState.activePlanId];
            const allocationValue = parseFloat(document.getElementById('calcAmount').value) || 0;

            if (systemState.userLedgerBalance < allocationValue) {
                alert("Allocation Blocked: Available Net Asset Valuation (NAV) balance is insufficient. Please execute a pipeline deposit.");
                return;
            }
            if (allocationValue < targetTier.minDeposit) {
                alert("Limit Violation: Minimum configuration parameters require at least $" + targetTier.minDeposit + " to connect to this tier.");
                return;
            }

            systemState.userLedgerBalance -= allocationValue;
            systemState.userLedgerYield += (allocationValue * targetTier.monthlyRate);
            systemState.activeContractsCount += 1;

            updateInterfaceLedgerCards();
            logSystemActivity("Locked $" + allocationValue.toLocaleString() + " to " + targetTier.name);
            
            await saveUserLedgerProfile();
            alert("Success! Allocation locked into computing node channels.");
        }

        function updateInterfaceLedgerCards() {
            const overallCumulativePortfolioValue = systemState.userLedgerBalance + systemState.userLedgerYield;
            document.getElementById('cardActiveDeposits').innerText = '$' + systemState.userLedgerBalance.toLocaleString(undefined, {minimumFractionDigits: 2});
            document.getElementById('cardTotalYield').innerText = '+$' + systemState.userLedgerYield.toLocaleString(undefined, {minimumFractionDigits: 2});
            document.getElementById('cardTotalValue').innerText = '$' + overallCumulativePortfolioValue.toLocaleString(undefined, {minimumFractionDigits: 2});
            document.getElementById('cardPlanCount').innerText = systemState.activeContractsCount + (systemState.activeContractsCount === 1 ? " Yield Pipeline Engaged" : " Yield Pipelines Engaged");
        }

        window.openTransactionModal = function(txType) {
            document.getElementById('txModal').classList.remove('hidden');
            if(txType === 'deposit') {
                document.getElementById('txModalTitle').innerText = "Fund Liquidity Port Allocation";
                document.getElementById('depositForm').classList.remove('hidden');
                document.getElementById('withdrawForm').classList.add('hidden');
            } else {
                document.getElementById('txModalTitle').innerText = "Execute Network Outlay Sequence";
                document.getElementById('depositForm').classList.add('hidden');
                document.getElementById('withdrawForm').classList.remove('hidden');
            }
        }

        window.closeTransactionModal = function() {
            document.getElementById('txModal').classList.add('hidden');
            document.getElementById('depositTxVal').value = '';
            document.getElementById('withdrawTxVal').value = '';
            document.getElementById('withdrawTxAddress').value = '';
        }

        window.executeWalletDepositReceipt = async function() {
            const amt = parseFloat(document.getElementById('depositTxVal').value) || 0;
            if(amt <= 0) {
                alert("Please declare a comprehensive, non-zero financial asset payload size.");
                return;
            }
            systemState.userLedgerBalance += amt;
            updateInterfaceLedgerCards();
            logSystemActivity("Inbound Ticket Logged: +$" + amt.toLocaleString());
            closeTransactionModal();
            
            await saveUserLedgerProfile();
            alert("Deposit ticket captured successfully. Balancing assets updates on internal ledger verification.");
        }

        window.executeWalletWithdrawalProcessing = async function() {
            const amt = parseFloat(document.getElementById('withdrawTxVal').value) || 0;
            const address = document.getElementById('withdrawTxAddress').value.trim();
            
            if(address === "") {
                alert("Please define a standard target destination clearing layer address string.");
                return;
            }
            if(amt <= 0 || amt > systemState.userLedgerBalance) {
                alert("The withdrawal asset size input parameters fall outside your active available NAV clear-pool limits.");
                return;
            }
            systemState.userLedgerBalance -= amt;
            updateInterfaceLedgerCards();
            logSystemActivity("Outbound Dispatched: -$" + amt.toLocaleString());
            closeTransactionModal();
            
            await saveUserLedgerProfile();
            alert("Liquidation process successfully queued into routing pipelines.");
        }

        function logSystemActivity(message) {
            const container = document.getElementById('ledgerActivityLogs');
            const timestamp = new Date().toLocaleTimeString();
            if(container.innerHTML.includes("italic")) container.innerHTML = "";
            
            const row = document.createElement('p');
            row.className = "border-b border-slate-900 pb-1 text-slate-300";
            row.innerHTML = `<span class="text-amber-500 font-bold">[${timestamp}]</span> ${message}`;
            container.prepend(row);
        }

        runActiveCalculation();
    </script>
</body>
</html>
