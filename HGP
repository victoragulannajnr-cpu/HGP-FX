        // Database Sync Helper: Pulls data from Firestore Cloud to UI
        async function fetchUserLedgerProfile(user) {
            try {
                const userDocRef = doc(db, "users", user.uid);
                const userDocSnap = await getDoc(userDocRef);

                if (userDocSnap.exists()) {
                    const cloudData = userDocSnap.data();
                    systemState.userLedgerBalance = cloudData.userLedgerBalance || 0.00;
                    systemState.userLedgerYield = cloudData.userLedgerYield || 0.00;
